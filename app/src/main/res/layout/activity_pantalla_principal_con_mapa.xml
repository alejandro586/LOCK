<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_black"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Mapa completo -->
        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Gradient superior -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/gradient_rojo_azul_turquesa"
            android:alpha="0.8"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Botón menú -->
        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu"
            app:tint="@color/primary_turquoise"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BARRA DE BÚSQUEDA con Places Autocomplete -->
        <fragment
            android:id="@+id/autocomplete_fragment"
            android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_menu" />

        <!-- Chips de zonas -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            app:layout_constraintBottom_toTopOf="@id/report_button"
            android:layout_marginBottom="80dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_legend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                app:singleLine="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_red_zones"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zonas Peligrosas"
                    android:textColor="@color/text_white"
                    app:chipBackgroundColor="@color/surface_grey"
                    app:chipStrokeColor="@color/rojo"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_yellow_zones"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zonas Riesgosas"
                    android:textColor="@color/text_white"
                    app:chipBackgroundColor="@color/surface_grey"
                    app:chipStrokeColor="@color/amarillo"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_safe_zones"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seguro"
                    android:textColor="@color/text_white"
                    app:chipBackgroundColor="@color/surface_grey"
                    app:chipStrokeColor="@color/primary_turquoise"
                    app:chipStrokeWidth="1dp" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- FAB reportar incidente -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/report_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPORTAR INCIDENTE"
            android:textColor="@color/text_white"
            app:icon="@drawable/ic_alert_red"
            app:iconTint="@color/text_white"
            app:backgroundTint="@color/rojo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="32dp"
            app:elevation="8dp" />

        <!-- FAB compartir ubicación -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/share_location_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_share"
            app:backgroundTint="@color/primary_turquoise"
            app:tint="@color/text_white"
            app:layout_constraintBottom_toBottomOf="@id/report_button"
            app:layout_constraintTop_toTopOf="@id/report_button"
            app:layout_constraintStart_toEndOf="@id/report_button"
            android:layout_marginStart="16dp"
            app:fabSize="mini" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/surface_grey"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/text_white"
        app:itemIconTint="@color/primary_turquoise">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cerrar Sesión"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:backgroundTint="@color/rojo"
                app:icon="@drawable/ic_cancel"
                app:iconTint="@color/text_white"
                app:iconGravity="textStart" />
        </FrameLayout>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>