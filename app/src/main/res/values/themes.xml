<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LockApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores base -->
        <item name="colorPrimary">@color/primary_turquoise</item>
        <item name="colorOnPrimary">@color/bg_light_black</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_white</item>

        <item name="colorSecondary">@color/surface_grey</item>
        <item name="colorOnSecondary">@color/text_white</item>

        <item name="android:windowBackground">@color/bg_light_black</item>
        <item name="android:statusBarColor">@color/bg_light_black</item>
        <item name="android:navigationBarColor">@color/bg_light_black</item>

        <!-- Colores de texto globales para asegurar visibilidad en fondo oscuro -->
        <item name="android:textColorPrimary">@color/text_white</item>
        <item name="android:textColorSecondary">@color/text_grey</item>
        <item name="android:textColorHint">@color/text_grey</item>

        <!-- Configuración de estilos de componentes -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.App.HeadlineLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.App.BodyMedium</item>

        <!-- Estilo para MaterialButtons de texto -->
        <item name="materialButtonStyle">@style/Widget.App.Button</item>

        <!-- Necesario para TextInputLayout -->
        <item name="isLightTheme">false</item>

        <!-- Custom Dialog Theme -->
        <item name="android:alertDialogTheme">@style/CustomAlertDialogTheme</item>
    </style>

    <style name="Theme.LockApp" parent="Base.Theme.LockApp" />

    <style name="TextAppearance.App.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_grey</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <!-- Por defecto los botones tendrán texto que contraste -->
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Style for Dark AlertDialog -->
    <style name="CustomAlertDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="colorSurface">@color/surface_grey</item>
        <item name="android:textColorPrimary">@color/text_white</item>
        <item name="android:textColorSecondary">@color/text_grey</item>
        <item name="android:background">@color/surface_grey</item>
    </style>
</resources>