<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_black"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:tint="@color/text_white"
        app:layout_constraintTop_toTopOf="@id/header_title"
        app:layout_constraintBottom_toBottomOf="@id/header_title"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configuración"
        style="@style/TextAppearance.App.HeadlineLarge"
        android:textSize="24sp"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        android:layout_marginTop="16dp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_lockdown"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/surface_grey"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/primary_turquoise"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/header_title"
        app:layout_constraintBottom_toTopOf="@+id/card_premium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/lockdown_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:text="Bloqueo Total"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:thumbTint="@color/primary_turquoise"
            app:trackTint="@color/primary_dark"
            android:padding="24dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/sim_detection_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:text="Detección de cambio de SIM"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lockdown_switch"
            app:thumbTint="@color/primary_turquoise"
            app:trackTint="@color/primary_dark"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="24dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/siren_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="false"
            android:text="Sirena anti-robo (máximo volumen)"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sim_detection_switch"
            app:thumbTint="@color/primary_turquoise"
            app:trackTint="@color/primary_dark"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="24dp" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bg_light_black"
            app:layout_constraintTop_toBottomOf="@id/siren_switch"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp" />

        <!-- Área scrollable para las descripciones largas -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_descriptions"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fillViewport="true"
            android:padding="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/description"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="Bloquea el dispositivo automáticamente si detectamos robo. Se desactiva solo con PIN o huella digital para mayor seguridad."
                    android:textColor="@color/text_grey"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/description_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Detecta cambios bruscos de aceleración si el teléfono es arrebatado de tus manos. El sistema bloquea el acceso a todas tus aplicaciones en menos de un segundo para evitar el robo de datos."
                    android:textColor="@color/text_grey"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/description" />

                <TextView
                    android:id="@+id/description_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Recibe alertas preventivas antes de entrar a calles con reportes de robo activos. El sistema utiliza datos validados por otros usuarios y fuentes oficiales en un radio de 200 metros."
                    android:textColor="@color/text_grey"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/description_2" />

                <TextView
                    android:id="@+id/description_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:text="En caso de robo confirmado, accede a nuestro panel de control remoto para borrar datos sensibles, activar la sirena de máximo volumen o bloquear el IMEI de manera permanente."
                    android:textColor="@color/text_grey"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/description_3" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

<com.google.android.material.card.MaterialCardView
android:id="@+id/card_premium"
android:layout_width="0dp"
android:layout_height="wrap_content"
app:cardBackgroundColor="@color/primary_turquoise"
app:cardCornerRadius="24dp"
app:layout_constraintBottom_toBottomOf="parent"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent"
android:layout_marginBottom="24dp">

<com.google.android.material.button.MaterialButton
    android:id="@+id/premium_button"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:text="Obtener Premium"
    app:icon="@drawable/ic_crown"
    app:iconGravity="textStart"
    app:iconTint="@color/bg_light_black"
    android:textSize="16sp"
    android:textStyle="bold"
    android:backgroundTint="@color/primary_turquoise"
    android:textColor="@color/bg_light_black"
    android:insetTop="0dp"
    android:insetBottom="0dp"
    app:cornerRadius="24dp"/>
</com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>