<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_rojo_azul_turquesa"
    android:padding="24dp">

    <TextView
        android:id="@+id/survey_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Qué ocurrió realmente?"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/blanco"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_si"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/turquesa"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/survey_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <RadioButton
            android:id="@+id/radio_si_robo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sí, robo confirmado"
            android:textSize="18sp"
            android:textColor="@color/blanco"
            android:buttonTint="@color/turquesa"
            android:padding="24dp"/>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/submit_survey"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Enviar confirmación"
        android:textSize="18sp"
        app:cornerRadius="28dp"
        android:backgroundTint="@color/turquesa"
        android:textColor="@color/blanco"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="48dp"
        android:enabled="false"/>
</androidx.constraintlayout.widget.ConstraintLayout>